{
  "name": "@ever-traduora/api",
  "version": "0.20.4",
  "license": "AGPL-3.0-only",
  "homepage": "https://traduora.co",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/ever-co/ever-traduora.git"
  },
  "bugs": {
    "url": "https://github.com/ever-co/ever-traduora/issues"
  },
  "private": true,
  "author": {
    "name": "Ever Co. LTD",
    "email": "ever@ever.co",
    "url": "https://ever.co"
  },
  "scripts": {
    "fmt": "prettier --write \"src/**/*.ts\"",
    "start": "cross-env TR_MAIL_DEBUG=true TR_CORS_ENABLED=true nodemon",
    "build": "tsc && copyfiles src/templates/**/* ../dist",
    "build:prod": "tsc && copyfiles src/templates/**/* ../dist",
    "clean": "rimraf ../dist/src ../dist/test",
    "lint": "tslint -p tsconfig.json -c tslint.json",
    "test": "cross-env NODE_OPTIONS=--max-old-space-size=3000 NODE_ENV=test jest --watchAll=false --maxWorkers=2",
    "test:watch": "cross-env NODE_ENV=test TR_ACCESS_LOGS_ENABLED=false jest --watch",
    "test:e2e": "cross-env NODE_ENV=e2e TR_DEFAULT_PROJECT_PLAN=default TR_ACCESS_LOGS_ENABLED=false TR_DB_DATABASE=tr_e2e jest --config ./test/jest-e2e.json --runInBand --verbose --detectOpenHandles --forceExit",
    "test:ci": "yarn test && yarn test:e2e",
    "typeorm": "ts-node node_modules/.bin/typeorm",
    "seed": "cross-env TR_SEED_DATA=true ts-node -r tsconfig-paths/register src/seeds/seed-cli.ts",
    "seed:default": "cross-env TR_SEED_DATA=true TR_DEFAULT_SEED_ONLY=true ts-node -r tsconfig-paths/register src/seeds/seed-cli.ts"
  },
  "dependencies": {
    "@nestjs/axios": "^3.1.0",
    "@nestjs/common": "^10.4.6",
    "@nestjs/config": "^3.3.0",
    "@nestjs/core": "^10.4.6",
    "@nestjs/jwt": "^10.2.0",
    "@nestjs/passport": "^10.0.3",
    "@nestjs/platform-express": "^10.4.6",
    "@nestjs/swagger": "^7.4.2",
    "@nestjs/throttler": "^6.3.0",
    "@nestjs/typeorm": "^10.0.2",
    "axios": "^1.7.7",
    "bcrypt": "^5.1.1",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.14.1",
    "csv": "^5.5.3",
    "csv-stringify": "^6.0.5",
    "dotenv": "^16.4.7",
    "ejs": "^3.1.10",
    "generate-password": "^1.6.1",
    "gettext-parser": "^4.0.4",
    "handlebars": "^4.7.8",
    "iconv-lite": "^0.6.3",
    "ioredis": "^5.6.0",
    "js-yaml": "^4.1.0",
    "lodash": "^4.17.21",
    "moment": "^2.30.1",
    "morgan": "^1.10.0",
    "mysql2": "^3.14.0",
    "node-native2ascii": "^0.2.0",
    "nodemailer": "^6.9.14",
    "passport": "^0.7.0",
    "passport-jwt": "^4.0.1",
    "pg": "^8.14.1",
    "php-array-parser": "^1.0.1",
    "preview-email": "^3.0.5",
    "properties": "^1.2.1",
    "query-string": "^7.0.0",
    "querystring": "^0.2.1",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.3.0",
    "strings-file": "^0.0.5",
    "swagger-ui-express": "^4.2.0",
    "typeorm": "^0.3.22",
    "xliff": "^5.6.2",
    "xml-js": "^1.6.11"
  },
  "devDependencies": {
    "@nestjs/cli": "^10.4.5",
    "@nestjs/testing": "^10.4.6",
    "@types/bcrypt": "^5.0.2",
    "@types/csv-stringify": "^3.1.0",
    "@types/express": "^5.0.0",
    "@types/express-serve-static-core": "^5.0.1",
    "@types/handlebars": "^4.1.0",
    "@types/iconv-lite": "^0.0.1",
    "@types/jest": "^29.5.14",
    "@types/js-yaml": "^4.0.9",
    "@types/moment": "^2.13.0",
    "@types/morgan": "^1.9.9",
    "@types/node": "^20.14.8",
    "@types/nodemailer": "^6.4.15",
    "@types/supertest": "^6.0.2",
    "copyfiles": "^2.4.1",
    "cross-env": "^7.0.3",
    "jest": "^29.7.0",
    "nodemon": "^3.1.4",
    "prettier": "^3.5.3",
    "rimraf": "^6.0.1",
    "semver-regex": "^4.0.5",
    "supertest": "^7.1.0",
    "ts-jest": "^29.3.1",
    "ts-loader": "^9.5.2",
    "ts-node": "^10.9.2",
    "tsconfig-paths": "^4.2.0",
    "tslint": "^6.1.3",
    "typescript": "^5.5.2",
    "webpack": "^5.95.0",
    "webpack-cli": "^5.1.4",
    "webpack-node-externals": "^3.0.0"
  },
  "jest": {
    "moduleFileExtensions": [
      "js",
      "json",
      "ts"
    ],
    "rootDir": "src",
    "testRegex": ".spec.ts$",
    "testTimeout": 30000,
    "transform": {
      "^.+\\.(t|j)s$": "ts-jest"
    },
    "coverageDirectory": "../coverage",
    "testEnvironment": "node"
  },
  "engines": {
    "node": ">=18.0.0",
    "yarn": ">=1.13.0"
  },
  "snyk": true
}